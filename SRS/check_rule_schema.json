{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Clinical Rule Compliance Check Report – Evidence Linked",
  "description": "Structured output of a compliance check against a clinical rule, including per-document supporting evidence.",
  "type": "object",
  "properties": {
    "check_id": {
      "type": "string",
      "description": "Unique identifier of this check instance."
    },
    "check_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "When the check was executed."
    },
    "rule_id": {
      "type": "string",
      "description": "Identifier of the evaluated rule."
    },
    "patient_id_hash": {
      "type": "string",
      "description": "Pseudonymized patient identifier."
    },
    "outcome": {
      "type": "string",
      "enum": [
        "compliant",
        "non_compliant",
        "justified_deviation",
        "not_applicable",
        "not_evaluable",
        "probable_non_compliance"
      ],
      "description": "Compliance outcome."
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence in the outcome (0 = none, 1 = full)."
    },
    "rationale": {
      "type": "string",
      "description": "Human-readable explanation of the outcome."
    },
    "supporting_documents": {
      "type": "array",
      "description": "Clinical documents that support the compliance outcome.",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "document_id": {
            "type": "string",
            "description": "Identifier of the supporting clinical document (as present in the episode data)."
          },
          "rationale": {
            "type": "string",
            "description": "Short rationale for how this document supports the outcome, aligned with the global rationale."
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Confidence that this specific document supports the outcome."
          }
        },
        "required": [
          "document_id",
          "rationale",
          "confidence"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "check_id",
    "check_timestamp",
    "rule_id",
    "patient_id_hash",
    "outcome",
    "confidence",
    "rationale",
    "supporting_documents"
  ],
  "additionalProperties": false
}
